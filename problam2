def palindrom(n):   
    temp = n
    rev = 0
    while n > 0:
        rem = n % 10
        rev = rev * 10 + rem
        n = n // 10
    
   
    return temp == rev
      

n = int(input("Enter an element: "))


if palindrom(n):
    print(n, "True")   
else:    
    print(n, "False")

